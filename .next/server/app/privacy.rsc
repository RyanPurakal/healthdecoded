f:["$","p",null,{"children":"We share information only with the service providers that run our infrastructure:"}]
10:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Supabase"}]," (authentication and database hosting)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Vercel"}]," (website hosting)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Google"}]," (sign-in authentication, if you choose that option)"]}]]}]
11:["$","p",null,{"children":"These providers process data on our behalf and are bound by their own privacy and security commitments; we don't share your information with anyone else."}]
12:["$","h2",null,{"children":"Children's Privacy"}]
13:["$","p",null,{"children":["Health Decoded's programs are designed for youth, and some users of this platform may be minors. We do not knowingly collect more information from a child than is necessary for them to participate as an ambassador or volunteer (name, email, school/organization, and event activity). Parents or guardians with questions or concerns about a minor's information can contact us at"," ",["$","a",null,{"href":"mailto:ryanp@healthdecodedinitiative.org","children":"ryanp@healthdecodedinitiative.org"}]," at any time, including to request that we delete their child's data."]}]
14:["$","h2",null,{"children":"Data Retention and Your Rights"}]
15:["$","p",null,{"children":["You can request access to, correction of, or deletion of your information at any time by contacting ",["$","a",null,{"href":"mailto:ryanp@healthdecodedinitiative.org","children":"ryanp@healthdecodedinitiative.org"}],". We retain account and activity data for as long as your account is active, or as needed to fulfill the purposes described above."]}]
16:["$","h2",null,{"children":"Changes to This Policy"}]
17:["$","p",null,{"children":"We may update this policy as the platform evolves. We'll update the “Last updated” date above when we do."}]
18:["$","h2",null,{"children":"Contact"}]
19:["$","p",null,{"children":["Questions about this policy or your data:"," ",["$","a",null,{"href":"mailto:ryanp@healthdecodedinitiative.org","children":"ryanp@healthdecodedinitiative.org"}]]}]
