children":"Last updated: July 20, 2026"}],["$","div",null,{"className":"hd-app-card news-post-body","children":[["$","p",null,{"children":"Health Decoded (“we,” “us,” “our”) is a youth-focused health literacy nonprofit. This policy explains what information we collect through healthdecodedinitiative.org and our ambassador/volunteer platform, and how we use it."}],["$","h2",null,{"children":"Information We Collect"}],["$","p",null,{"children":"When you sign in with Google, we receive your name, email address, and profile picture from your Google account. If you sign in via magic link instead, we collect only the email address you provide."}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19"]}]]}]}],null,"$L1a"]}],{},null,false]},null,false]},null,false],"$L1b",false]],"m":"$undefined","G":["$1c",[]],"s":false,"S":true}
