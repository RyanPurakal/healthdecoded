7:["$","p",null,{"children":"When you use the platform, we also collect:"}]
8:["$","ul",null,{"children":[["$","li",null,{"children":"Profile information you provide (school or organization, role as ambassador or volunteer)"}],["$","li",null,{"children":"Event registrations (which events you sign up for and attend)"}],["$","li",null,{"children":"Activity within the platform (actions like registering for events, tied to your account)"}]]}]
9:["$","p",null,{"children":"We do not collect payment information, government ID numbers, or any sensitive personal data beyond what's listed above."}]
a:["$","h2",null,{"children":"How We Use Your Information"}]
b:["$","p",null,{"children":"We use this information to:"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":"Create and maintain your account"}],["$","li",null,{"children":"Let you register for and track events"}],["$","li",null,{"children":"Show you your own activity and registration history on your dashboard"}],["$","li",null,{"children":"Operate and improve the platform"}]]}]
d:["$","p",null,{"children":"We do not sell your information, and we do not share it with third parties for advertising or marketing purposes."}]
